# Neon or other Postgres connection string injected by Vercel Marketplace
DATABASE_URL=

# Optional legacy fallback used by some Postgres integrations
POSTGRES_URL=

# Vercel Blob read/write token for cropped profile image uploads.
# Connecting a Blob store to the Vercel project injects this automatically.
BLOB_READ_WRITE_TOKEN=

# Google OAuth Web client ID used for Google account login.
# Create an OAuth "Web application" client in Google Cloud, then add your site URL
# to Authorized JavaScript origins before setting this value in Vercel/local env.
GOOGLE_CLIENT_ID=

# Email sign-up/login through SMTP. Gmail app passwords should be stored only
# in local/Vercel env vars, without spaces.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional auth tuning
AUTH_SESSION_DAYS=30
EMAIL_AUTH_CODE_TTL_MINUTES=10
EMAIL_AUTH_CODE_MAX_ATTEMPTS=5
AUTH_CODE_SECRET=

# Optional save password override. Defaults to 027619 when omitted.
SAVE_PASSWORD=027619
