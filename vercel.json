  "regions": ["sin1"],
  "redirects": [
    {
      "source": "/cues.html",
      "destination": "/workspace.html?tool=cue",
      "permanent": true
    },
    {
      "source": "/cues",
      "destination": "/workspace.html?tool=cue",
